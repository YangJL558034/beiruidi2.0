{
  "name": "sza-power-global-site",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "dev:local": "next dev --hostname 127.0.0.1",
    "validate:env": "node --env-file-if-exists=.env scripts/validate-production-env.mjs",
    "prebuild": "npm run validate:env",
    "build": "next build",
    "prestart": "npm run validate:env",
    "start": "next start --hostname 0.0.0.0",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:smoke": "node --env-file-if-exists=.env scripts/smoke-test.mjs",
    "verify": "npm run lint && npm run typecheck && npm run build && npm run test:smoke",
    "check": "npm run verify"
  },
  "dependencies": {
    "@types/nodemailer": "8.0.1",
    "framer-motion": "12.42.2",
    "lucide-react": "1.24.0",
    "next": "16.2.11",
    "nodemailer": "9.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.11",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.22",
    "sharp": "0.35.0"
  }
}
