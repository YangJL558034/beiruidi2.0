NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
SZA_SESSION_SECRET=replace-with-a-long-random-secret
SZA_ADMIN_EMAIL=admin@sza-power.com
SZA_SQLITE_PATH=./data/sza-power.sqlite
SZA_ALLOWED_DEV_ORIGINS=example.com,*.example.com
SZA_TRUSTED_ORIGINS=https://example.com,https://www.example.com
SZA_ADMIN_PASSWORD=replace-with-a-strong-password
SZA_SUPPORT_ATTACHMENT_PATH=./data/support-attachments
SZA_SUPPORT_MAX_FILE_BYTES=10485760
SZA_REQUIRE_MALWARE_SCAN=true
SZA_CLAMAV_HOST=127.0.0.1
SZA_CLAMAV_PORT=3310
# 默认使用网易 163 邮箱：QQ 邮箱请将主机改为 smtp.qq.com。
# 两者均建议使用 465 端口和邮箱后台生成的 SMTP 授权码，不要填写登录密码。
SZA_SMTP_HOST=smtp.163.com
SZA_SMTP_PORT=465
SZA_SMTP_USER=your-account@163.com
SZA_SMTP_PASSWORD=replace-with-smtp-authorization-code
SZA_SMTP_FROM="BarryT Support <your-account@163.com>"
